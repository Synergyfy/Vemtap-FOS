{
  "name": "vemtap-fos",
  "private": true,
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "lint": "pnpm -C apps/web lint",
    "start": "pnpm -C apps/web start",
    "clean": "pnpm -C apps/web clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
